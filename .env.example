# Mosaic runtime profile selection
MOSAIC_ACTIVE_PROFILE=openai

# Operator and Gateway auth
MOSAIC_OPERATOR_TOKEN=replace-with-a-long-random-token
MOSAIC_WEBCHAT_SHARED_SECRET=replace-with-a-webchat-shared-secret
MOSAIC_TELEGRAM_SECRET_TOKEN=replace-with-a-telegram-secret-token

# Provider credentials
OPENAI_API_KEY=replace-with-openai-key
AZURE_OPENAI_API_KEY=replace-with-azure-openai-key
ANTHROPIC_API_KEY=replace-with-anthropic-key
COMPAT_API_KEY=replace-with-compatible-provider-key
